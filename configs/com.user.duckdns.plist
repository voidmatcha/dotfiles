<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.user.duckdns</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/curl</string>
    <string>-s</string>
    <string>-o</string>
    <string>/tmp/duckdns.log</string>
    <string>https://www.duckdns.org/update?domains=__DUCKDNS_DOMAIN__&amp;token=__DUCKDNS_TOKEN__&amp;ip=</string>
  </array>
  <key>StartInterval</key>
  <integer>300</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardErrorPath</key>
  <string>/tmp/duckdns.err</string>
</dict>
</plist>
