<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.user.opencode-web</string>
  <key>ProgramArguments</key>
  <array>
    <string>__WRAPPER_PATH__</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>60</integer>
  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/opencode-web.out.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/opencode-web.err.log</string>
</dict>
</plist>
